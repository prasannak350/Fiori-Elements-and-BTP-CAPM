{
  "_version": "1.82.0",
  "sap.app": {
    "id": "btpuiassessments",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.20.4",
      "toolsId": "43434d94-124f-427e-8d4a-f086b89fce05"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/full-stack/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "Assessments-manageCAP": {
          "semanticObject": "Assessments",
          "action": "manageCAP",
          "title": "{{Assessments-manageCAP.flpTitle}}",
          "subTitle": "{{Assessments-manageCAP.flpSubtitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.145.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "btpuiassessments.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "AssessmentsList",
          "target": "AssessmentsList"
        },
        {
          "pattern": "Assessments({key}):?query:",
          "name": "AssessmentsObjectPage",
          "target": "AssessmentsObjectPage"
        },
        {
          "pattern": "Assessments({key})/Observations({key2}):?query:",
          "name": "ObservationsObjectPage",
          "target": "ObservationsObjectPage"
        }
      ],
      "targets": {
        "AssessmentsList": {
          "type": "Component",
          "id": "AssessmentsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/Assessments",
              "variantManagement": "Page",
              "navigation": {
                "Assessments": {
                  "detail": {
                    "route": "AssessmentsObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  }
                }
              }
            }
          }
        },
        "AssessmentsObjectPage": {
          "type": "Component",
          "id": "AssessmentsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/Assessments",
              "navigation": {
                "Observations": {
                  "detail": {
                    "route": "ObservationsObjectPage"
                  }
                }
              }
            }
          }
        },
        "ObservationsObjectPage": {
          "type": "Component",
          "id": "ObservationsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/Assessments/Observations"
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  },
  "sap.cloud": {
    "public": true,
    "service": "ui_managedapprouter"
  }
}
