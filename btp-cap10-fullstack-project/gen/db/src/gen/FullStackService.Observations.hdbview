VIEW FullStackService_Observations AS SELECT
  OBSERVATIONS_0.ID,
  OBSERVATIONS_0.createdAt,
  OBSERVATIONS_0.createdBy,
  OBSERVATIONS_0.modifiedAt,
  OBSERVATIONS_0.modifiedBy,
  OBSERVATIONS_0.DESCRIPTION,
  OBSERVATIONS_0.IS_CRITICAL,
  OBSERVATIONS_0.ASSESSMENTS_ID
FROM btp_fs_OBSERVATIONS AS OBSERVATIONS_0