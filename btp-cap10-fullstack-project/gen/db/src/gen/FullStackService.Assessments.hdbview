VIEW FullStackService_Assessments AS SELECT
  ASSESSMENTS_0.ID,
  ASSESSMENTS_0.createdAt,
  ASSESSMENTS_0.createdBy,
  ASSESSMENTS_0.modifiedAt,
  ASSESSMENTS_0.modifiedBy,
  ASSESSMENTS_0.DESCRIPTION,
  ASSESSMENTS_0.START_DATE,
  ASSESSMENTS_0.END_DATE,
  ASSESSMENTS_0.CATEGORY
FROM btp_fs_ASSESSMENTS AS ASSESSMENTS_0